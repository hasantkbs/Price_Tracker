# ── iOS AdMob (App Store production) ─────────────────────────────────────────
# Bu değerleri Xcode Build Settings veya project.yml Release'e girin.
# Ayrıntı: PriceTrackerApp/AdMob.SETUP.md
# GAD_APP_ID=ca-app-pub-XXXXXXXX~XXXXXXXXXX
# GAD_BANNER_UNIT_ID=ca-app-pub-XXXXXXXX/YYYYYYYYYY
# GAD_REWARDED_UNIT_ID=ca-app-pub-XXXXXXXX/YYYYYYYYYY
# GAD_INTERSTITIAL_UNIT_ID=ca-app-pub-XXXXXXXX/YYYYYYYYYY

# ── Genel ────────────────────────────────────────────────────────────────────
# Yayımlanacak dış port (host makinede)
API_PORT=8001

# Docker image etiketi
IMAGE_TAG=latest

# ── Caddy HTTPS (proxy profili ile kullanılır) ────────────────────────────────
# Kendi domain adınızı buraya yazın
DOMAIN=api.example.com
