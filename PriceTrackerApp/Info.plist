<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ─── Bundle ─── -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>$(PRODUCT_DISPLAY_NAME)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>PriceTracker</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- ─── Google AdMob ─── -->
	<!-- TODO: GAD_APP_ID değerini Xcode Build Settings → GAD_APP_ID alanına kendi AdMob App ID'nizle (ca-app-pub-XXXXXXXX~XXXXXXXXXX) girin -->
	<key>GADApplicationIdentifier</key>
	<string>$(GAD_APP_ID)</string>
	<key>GADIsAdManagerApp</key>
	<false/>

	<!-- ─── Network – web scraping için arbitrary loads açık ─── -->
	<!-- App Store Review notuna gerekçe ekleyin: kullanıcının girdiği e-ticaret URL'leri -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>

	<!-- ─── Permissions ─── -->
	<key>NSUserNotificationUsageDescription</key>
	<string>Takip ettiğiniz ürünlerin fiyatı düştüğünde bildirim almak için izin gerekiyor.</string>

	<!-- ─── Background Modes ─── -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>

	<!-- ─── Background Task Identifiers ─── -->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.algorix.pricetracker.pricecheck</string>
	</array>

	<!-- ─── Scene ─── -->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict/>
	</dict>

	<!-- ─── Launch Screen – boş (SplashView SwiftUI ile yapılıyor) ─── -->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>systemBackground</string>
	</dict>

	<!-- ─── SKAdNetwork – AdMob gereklilikleri ─── -->
	<key>SKAdNetworkItems</key>
